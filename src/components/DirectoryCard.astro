---
import type { Directory } from "../data/directories";

type Props = { directory: Directory };
const { directory } = Astro.props;
const isFirst = directory.rank === 1;
const rankLabel = directory.rank.toString().padStart(2, "0");
---

<article
  class:list={[
    "group relative grid gap-6 px-6 py-10 transition-colors sm:grid-cols-[120px_1fr] sm:gap-10 sm:px-8 sm:py-12",
    isFirst ? "bg-accent-soft/40" : "hover:bg-paper-soft/60",
  ]}
>
  <div class="flex items-start justify-between sm:block">
    <div class="flex flex-col">
      <span
        class:list={[
          "font-numerals font-mono text-6xl leading-none tracking-tight sm:text-7xl",
          isFirst ? "text-accent" : "text-ink/85",
        ]}
      >
        {rankLabel}
      </span>
      {
        directory.established && (
          <span class="mt-3 font-mono text-[10px] uppercase tracking-[0.2em] text-ink-muted">
            Est. {directory.established}
          </span>
        )
      }
    </div>

    {
      directory.highlight && (
        <span class="font-serif text-xs italic text-accent sm:hidden">
          ★ {directory.highlight}
        </span>
      )
    }
  </div>

  <div class="flex flex-col gap-4">
    <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
      <h3 class="font-serif text-3xl leading-tight tracking-tight text-ink">
        {directory.name}
      </h3>
      <span
        class="font-mono text-[11px] uppercase tracking-[0.18em] text-ink-muted"
      >
        {directory.domain}
      </span>
      {
        directory.highlight && (
          <span class="hidden rounded-full border border-accent/30 bg-paper px-2.5 py-1 font-serif text-[11px] italic text-accent sm:inline-block">
            ★ {directory.highlight}
          </span>
        )
      }
    </div>

    <p class="text-base leading-relaxed text-ink-soft">
      {directory.description}
    </p>

    <a
      href={directory.url}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex w-fit items-center gap-2 border-b border-ink/20 pb-1 font-mono text-[11px] uppercase tracking-[0.22em] text-ink transition-colors hover:border-accent hover:text-accent"
    >
      Visit {directory.domain}
      <span
        aria-hidden="true"
        class="transition-transform duration-300 group-hover:translate-x-1"
        >→</span
      >
    </a>
  </div>
</article>
